generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ============================================
// ENUMS
// ============================================

enum Role {
  STUDENT
  INSTRUCTOR
  ADMIN
}

enum QuizStatus {
  DRAFT
  PUBLISHED
  FINISHED
}

enum QuizAccessType {
  ALL_IN_ORG
  BATCH_ONLY
  SPECIFIC_USERS
}

enum QuestionType {
  MCQ
  SINGLE_OPTION
  TRUE_FALSE
  CODING_QUESTION
}

enum AttemptStatus {
  IN_PROGRESS
  SUBMITTED
  ABANDONED
}

enum EnrollmentStatus {
  PENDING_ADMIN    // Instructor invited, waiting admin approval
  PENDING_INSTRUCTOR // Admin approved, waiting instructor to confirm
  ACTIVE           // Fully enrolled
  REJECTED         // Admin or instructor rejected
}

// ============================================
// CORE MODELS
// ============================================

model User {
  id        String   @id // Clerk user ID
  email     String   @unique
  firstName String   @map("first_name")
  lastName  String   @map("last_name")
  role      Role     @default(STUDENT)

  orgId     String?  @map("org_id")
  org       Org?     @relation(fields: [orgId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  batchInstructors BatchInstructor[]
  batchStudents    BatchStudent[]
  quizzesCreated   Quiz[]            @relation("QuizCreator")
  quizInvitations  QuizInvitation[]
  attempts         Attempt[]

  @@index([email])
  @@index([orgId])
  @@index([role])
  @@map("users")
}

model Org {
  id          String   @id @default(cuid())
  name        String
  description String?
  adminId     String?  @unique @map("admin_id")

  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  users       User[]
  batches     Batch[]
  quizzes     Quiz[]

  @@index([adminId])
  @@map("orgs")
}

model Batch {
  id          String   @id @default(cuid())
  name        String
  subject     String   // e.g. "Java & Spring Boot"
  description String?
  color       String   @default("amber") // UI color hint
  joinCode    String?  @unique @map("join_code") // Optional join code

  orgId       String   @map("org_id")
  org         Org      @relation(fields: [orgId], references: [id], onDelete: Cascade)

  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  instructors BatchInstructor[]
  students    BatchStudent[]
  quizzes     QuizBatch[]

  @@index([orgId])
  @@index([joinCode])
  @@map("batches")
}

model BatchInstructor {
  id           String   @id @default(cuid())
  batchId      String   @map("batch_id")
  batch        Batch    @relation(fields: [batchId], references: [id], onDelete: Cascade)
  instructorId String   @map("instructor_id")
  instructor   User     @relation(fields: [instructorId], references: [id], onDelete: Cascade)
  assignedAt   DateTime @default(now()) @map("assigned_at")

  @@unique([batchId, instructorId])
  @@index([batchId])
  @@index([instructorId])
  @@map("batch_instructors")
}

// Tracks student enrollment with admin-approval workflow
model BatchStudent {
  id         String           @id @default(cuid())
  batchId    String           @map("batch_id")
  batch      Batch            @relation(fields: [batchId], references: [id], onDelete: Cascade)
  studentId  String           @map("student_id")
  student    User             @relation(fields: [studentId], references: [id], onDelete: Cascade)

  status     EnrollmentStatus @default(PENDING_ADMIN)
  invitedBy  String?          @map("invited_by") // instructor user ID who invited
  invitedAt  DateTime         @default(now()) @map("invited_at")
  enrolledAt DateTime?        @map("enrolled_at") // set when status → ACTIVE

  @@unique([batchId, studentId])
  @@index([batchId])
  @@index([studentId])
  @@index([status])
  @@map("batch_students")
}

// ============================================
// QUIZ MODELS
// ============================================

model Quiz {
  id                     String         @id @default(cuid())
  title                  String
  description            String?
  subject                String         @default("General") // e.g. "Java", "DBMS"
  difficulty             String         @default("MEDIUM")  // EASY | MEDIUM | HARD
  joinCode               String?        @unique @map("join_code")

  orgId                  String         @map("org_id")
  org                    Org            @relation(fields: [orgId], references: [id], onDelete: Cascade)

  createdBy              String         @map("created_by")
  creator                User           @relation("QuizCreator", fields: [createdBy], references: [id], onDelete: Restrict)

  accessType             QuizAccessType @default(ALL_IN_ORG) @map("access_type")
  totalTimeLimit         Int?           @map("total_time_limit") // minutes
  status                 QuizStatus     @default(DRAFT)

  beginWindow            DateTime?      @map("begin_window")
  endWindow              DateTime?      @map("end_window")
  showResultsImmediately Boolean        @default(true) @map("show_results_immediately")

  // Scoring
  passScore              Float?         @map("pass_score") // percentage threshold (e.g. 60)
  correctPoints          Float          @default(4) @map("correct_points")
  wrongPoints            Float          @default(-1) @map("wrong_points")

  createdAt              DateTime       @default(now()) @map("created_at")
  updatedAt              DateTime       @updatedAt @map("updated_at")
  publishedAt            DateTime?      @map("published_at")

  sections               Section[]
  invitations            QuizInvitation[]
  attempts               Attempt[]
  batches                QuizBatch[]    // which batches this quiz is assigned to

  @@index([orgId])
  @@index([createdBy])
  @@index([status])
  @@index([beginWindow])
  @@index([endWindow])
  @@index([joinCode])
  @@map("quizzes")
}

// Many-to-many: a quiz can be assigned to multiple batches
model QuizBatch {
  id        String   @id @default(cuid())
  quizId    String   @map("quiz_id")
  quiz      Quiz     @relation(fields: [quizId], references: [id], onDelete: Cascade)
  batchId   String   @map("batch_id")
  batch     Batch    @relation(fields: [batchId], references: [id], onDelete: Cascade)
  assignedAt DateTime @default(now()) @map("assigned_at")

  @@unique([quizId, batchId])
  @@index([quizId])
  @@index([batchId])
  @@map("quiz_batches")
}

model QuizInvitation {
  id        String   @id @default(cuid())
  quizId    String   @map("quiz_id")
  quiz      Quiz     @relation(fields: [quizId], references: [id], onDelete: Cascade)
  userId    String   @map("user_id")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  invitedAt DateTime @default(now()) @map("invited_at")

  @@unique([quizId, userId])
  @@index([quizId])
  @@index([userId])
  @@map("quiz_invitations")
}

model Section {
  id                  String   @id @default(cuid())
  quizId              String   @map("quiz_id")
  quiz                Quiz     @relation(fields: [quizId], references: [id], onDelete: Cascade)
  title               String
  instructions        String?  @db.Text
  order               Int
  sectionalTimeLimit  Int?     @map("sectional_time_limit")
  sectionalPassScore  Float?   @map("sectional_pass_score")
  sectionalTotalScore Float    @map("sectional_total_score")
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")
  questions           Question[]

  @@index([quizId])
  @@index([order])
  @@map("sections")
}

model Question {
  id           String       @id @default(cuid())
  sectionId    String       @map("section_id")
  section      Section      @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  questionType QuestionType @map("question_type")
  questionText String       @db.Text @map("question_text")
  order        Int
  points       Float        @default(4)
  codeTemplate String?      @db.Text @map("code_template")
  testCases    Json?        @map("test_cases")
  explanation  String?      @db.Text
  createdAt    DateTime     @default(now()) @map("created_at")
  updatedAt    DateTime     @updatedAt @map("updated_at")
  options      Option[]
  answers      Answer[]

  @@index([sectionId])
  @@index([order])
  @@map("questions")
}

model Option {
  id         String   @id @default(cuid())
  questionId String   @map("question_id")
  question   Question @relation(fields: [questionId], references: [id], onDelete: Cascade)
  optionText String   @db.Text @map("option_text")
  isCorrect  Boolean  @default(false) @map("is_correct")
  order      Int
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")
  answers    Answer[]

  @@index([questionId])
  @@index([order])
  @@map("options")
}

// ============================================
// ANALYTICS & RESULTS MODELS
// ============================================

model Attempt {
  id              String        @id @default(cuid())
  userId          String        @map("user_id")
  user            User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  quizId          String        @map("quiz_id")
  quiz            Quiz          @relation(fields: [quizId], references: [id], onDelete: Cascade)
  attemptNumber   Int           @map("attempt_number")
  status          AttemptStatus @default(IN_PROGRESS)
  startedAt       DateTime      @default(now()) @map("started_at")
  submittedAt     DateTime?     @map("submitted_at")
  timeSpent       Int?          @map("time_spent") // seconds
  totalScore      Float?        @map("total_score")
  maxScore        Float?        @map("max_score")
  percentageScore Float?        @map("percentage_score")
  passed          Boolean?
  ipAddress       String?       @map("ip_address")
  userAgent       String?       @map("user_agent")
  createdAt       DateTime      @default(now()) @map("created_at")
  updatedAt       DateTime      @updatedAt @map("updated_at")
  answers         Answer[]

  @@unique([userId, quizId, attemptNumber])
  @@index([userId])
  @@index([quizId])
  @@index([status])
  @@index([startedAt])
  @@map("attempts")
}

model Answer {
  id              String   @id @default(cuid())
  attemptId       String   @map("attempt_id")
  attempt         Attempt  @relation(fields: [attemptId], references: [id], onDelete: Cascade)
  questionId      String   @map("question_id")
  question        Question @relation(fields: [questionId], references: [id], onDelete: Restrict)
  optionId        String?  @map("option_id")
  option          Option?  @relation(fields: [optionId], references: [id], onDelete: SetNull)
  selectedOptions Json?    @map("selected_options") // for MCQ: array of option IDs
  textAnswer      String?  @db.Text @map("text_answer")
  isCorrect       Boolean? @map("is_correct")
  pointsEarned    Float?   @map("points_earned")
  timeSpent       Int?     @map("time_spent")
  answeredAt      DateTime @default(now()) @map("answered_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  @@index([attemptId])
  @@index([questionId])
  @@index([optionId])
  @@map("answers")
}
